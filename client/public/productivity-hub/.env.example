# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/flowsstate

# JWT Configuration (Required - no fallback!)
# Generate a secure random value:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secure-random-secret-here-minimum-32-characters

# Email Service Configuration
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# Frontend URL Configuration
# For local development:
# FRONTEND_URL=http://localhost:5000
# For production:
FRONTEND_URL=https://flowsstate.example.com

# Server Port
PORT=3001

# Replit Configuration (if running on Replit)
# REPLIT_DEV_DOMAIN=your-replit-domain.repl.co

# Google Cloud Storage (for file uploads)
# GCS_PROJECT_ID=your-project-id
# GCS_BUCKET_NAME=your-bucket-name

# Node Environment
NODE_ENV=development
# Set to 'production' for production deployments
